# API Configuration
# The URL of the Payload CMS backend
VITE_API_URL=http://localhost:3000

# Default proposal slug to load (optional)
# If not set and no slug in URL, mock data will be used
VITE_DEFAULT_SLUG=

# Use mock data instead of API (true/false)
# Set to 'true' to always use mock data for development
VITE_USE_MOCK=false
