# ===========================================
# Payload CMS - Environment Variables
# ===========================================

# Database Connection (PostgreSQL)
# Local development (Docker): postgresql://payload_dev:dev_password_local@localhost:5432/payload_dev
# Production (Dokploy): postgresql://user:password@postgres-service:5432/payload
DATABASE_URL=postgresql://payload_dev:dev_password_local@localhost:5432/payload_dev

# Payload Secret (generate with: openssl rand -hex 32)
# MUST be at least 32 characters
PAYLOAD_SECRET=YOUR_SECRET_HERE_MIN_32_CHARS

# Public URL (used for links and API calls)
# Local: http://localhost:3000
# Production: https://cms.alinhadamente.pt
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Environment
NODE_ENV=development

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins for CORS/CSRF
# Production example: https://alinhadamente.pt,https://www.alinhadamente.pt,https://propostas.alinhadamente.pt
# Leave empty for development (localhost origins are auto-added)
ALLOWED_ORIGINS=

# ===========================================
# S3 Storage (Wasabi) - Required for production
# ===========================================
# Uncomment and configure before deploying to production
# S3_BUCKET=alinhadamente-uploads
# S3_REGION=eu-central-2
# S3_ENDPOINT=https://s3.eu-central-2.wasabisys.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
